<Window x:Class="SalaamStreet.Desktop.TafsirWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tafsir" Height="560" Width="560"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Bg}" Foreground="{StaticResource Text}">
    <DockPanel Margin="22">
        <StackPanel DockPanel.Dock="Top">
            <TextBlock Text="Tafsir Ibn Kathir" Style="{StaticResource H2}" />
            <TextBlock x:Name="RefText" Style="{StaticResource Tiny}" />
            <TextBlock Text="Abridged, English · via the open tafsir_api" Style="{StaticResource Tiny}" Margin="0,0,0,10" />
        </StackPanel>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <TextBlock x:Name="Body" Foreground="{StaticResource Text2}" TextWrapping="Wrap" LineHeight="22" />
        </ScrollViewer>
    </DockPanel>
</Window>
