<Window x:Class="SalaamStreet.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="SalaamStreet" Height="780" Width="1180"
        MinHeight="600" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Bg}"
        Foreground="{StaticResource Text}"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">

    <Window.InputBindings>
        <KeyBinding Key="D1" Modifiers="Ctrl" Command="{Binding NavCommand}" CommandParameter="dashboard" />
        <KeyBinding Key="D2" Modifiers="Ctrl" Command="{Binding NavCommand}" CommandParameter="prayer" />
        <KeyBinding Key="D3" Modifiers="Ctrl" Command="{Binding NavCommand}" CommandParameter="qibla" />
        <KeyBinding Key="D4" Modifiers="Ctrl" Command="{Binding NavCommand}" CommandParameter="quran" />
        <KeyBinding Key="D5" Modifiers="Ctrl" Command="{Binding NavCommand}" CommandParameter="learn" />
        <KeyBinding Key="OemComma" Modifiers="Ctrl" Command="{Binding NavCommand}" CommandParameter="settings" />
        <KeyBinding Key="F11" Command="{Binding FullScreenCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="238" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ══════════ Sidebar ══════════ -->
        <Border Grid.Column="0" Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Brand -->
                <StackPanel DockPanel.Dock="Top" Margin="18,20,18,10">
                    <TextBlock FontSize="21" FontWeight="Bold">
                        <Run Text="Salaam" Foreground="{StaticResource EmeraldStrong}" /><Run Text="Street" Foreground="{StaticResource Gold}" />
                    </TextBlock>
                    <TextBlock Text="Your Islamic companion" Style="{StaticResource Tiny}" Margin="0,2,0,0" />
                </StackPanel>

                <!-- Account chip -->
                <Border DockPanel.Dock="Bottom" Margin="12,8,12,14" Style="{StaticResource Card}" Padding="12"
                        Background="{StaticResource Surface2}" Cursor="Hand" MouseLeftButtonUp="Account_Click">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Width="34" Height="34" CornerRadius="999" Background="{StaticResource EmeraldDark}" Margin="0,0,10,0">
                            <TextBlock x:Name="Avatar" Text="?" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="AccountName" Text="Guest" FontWeight="SemiBold" FontSize="12.5" />
                            <TextBlock x:Name="AccountSub" Text="Sign in to sync" Style="{StaticResource Tiny}" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <TextBlock DockPanel.Dock="Bottom" Text="Ctrl+1…5 navigate · F11 study mode" Style="{StaticResource Tiny}" Margin="18,0,18,6" />

                <!-- Nav -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,6,0,0">
                    <StackPanel x:Name="NavPanel">
                        <RadioButton Style="{StaticResource NavButton}" Content="🏠  Dashboard" IsChecked="True" Tag="dashboard" Checked="Nav_Checked" />
                        <RadioButton Style="{StaticResource NavButton}" Content="🕰️  Prayer Times" Tag="prayer" Checked="Nav_Checked" />
                        <RadioButton Style="{StaticResource NavButton}" Content="🧭  Qibla" Tag="qibla" Checked="Nav_Checked" />
                        <RadioButton Style="{StaticResource NavButton}" Content="📖  Qur'an" Tag="quran" Checked="Nav_Checked" />
                        <RadioButton Style="{StaticResource NavButton}" Content="📜  Hadith" Tag="hadith" Checked="Nav_Checked" />
                        <RadioButton Style="{StaticResource NavButton}" Content="🤲  Duas" Tag="duas" Checked="Nav_Checked" />
                        <RadioButton Style="{StaticResource NavButton}" Content="📿  Dhikr" Tag="dhikr" Checked="Nav_Checked" />
                        <RadioButton Style="{StaticResource NavButton}" Content="🗓️  Calendar" Tag="calendar" Checked="Nav_Checked" />
                        <RadioButton Style="{StaticResource NavButton}" Content="🅰️  Learn Arabic" Tag="learn" Checked="Nav_Checked" />
                        <RadioButton Style="{StaticResource NavButton}" Content="⭐  Premium" Tag="premium" Checked="Nav_Checked" />
                        <RadioButton Style="{StaticResource NavButton}" Content="⚙️  Settings" Tag="settings" Checked="Nav_Checked" />
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ══════════ Content ══════════ -->
        <ContentControl x:Name="ContentHost" Grid.Column="1" />

        <!-- System tray icon -->
        <tb:TaskbarIcon x:Name="Tray" ToolTipText="SalaamStreet" TrayLeftMouseUp="Tray_Open" Visibility="Collapsed">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Open SalaamStreet" Click="Tray_Open" />
                    <MenuItem Header="Next prayer…" Click="Tray_NextPrayer" />
                    <Separator />
                    <MenuItem Header="Exit" Click="Tray_Exit" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Grid>
</Window>
