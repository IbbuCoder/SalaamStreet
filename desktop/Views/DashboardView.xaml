<UserControl x:Class="SalaamStreet.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28">
        <StackPanel MaxWidth="820" HorizontalAlignment="Left">
            <TextBlock Text="As-salamu alaykum" Style="{StaticResource Muted}" />
            <TextBlock Text="Dashboard" Style="{StaticResource H1}" Margin="0,2,0,18" />

            <!-- Next prayer hero -->
            <Border Style="{StaticResource Card}" Background="{StaticResource EmeraldDeep}" BorderThickness="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Next prayer" Foreground="#A7F3D0" FontSize="13" />
                        <TextBlock x:Name="NextName" Text="—" Foreground="White" FontSize="30" FontWeight="Bold" />
                        <TextBlock x:Name="LocLabel" Text="" Foreground="#A7F3D0" FontSize="12" Margin="0,4,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <TextBlock x:Name="Countdown" Text="--:--:--" Foreground="White" FontSize="30" FontWeight="Bold" />
                        <TextBlock x:Name="Hijri" Text="" Foreground="#A7F3D0" FontSize="12" HorizontalAlignment="Right" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Quick tiles -->
            <UniformGrid Columns="2" Margin="0,16,0,0">
                <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="📖  Continue reading" FontWeight="SemiBold" Foreground="{StaticResource Text}" />
                        <TextBlock x:Name="LastRead" Text="—" Style="{StaticResource Muted}" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="📥  Offline Qur'an" FontWeight="SemiBold" Foreground="{StaticResource Text}" />
                        <TextBlock x:Name="OfflineCount" Text="—" Style="{StaticResource Muted}" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="Today's prayers" FontWeight="SemiBold" Foreground="{StaticResource Text}" Margin="0,0,0,8" />
                    <ItemsControl x:Name="TimesList" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
