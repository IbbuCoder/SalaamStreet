<UserControl x:Class="SalaamStreet.Desktop.Views.DhikrView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28">
        <StackPanel MaxWidth="620" HorizontalAlignment="Left">
            <TextBlock Text="Dhikr Counter" Style="{StaticResource H1}" />
            <TextBlock Text="Remembrance of Allah — with daily streaks. Press Space or click to count." Style="{StaticResource Muted}" Margin="0,2,0,16" />

            <WrapPanel x:Name="Presets" />

            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="DhikrText" FontSize="30" FlowDirection="RightToLeft" HorizontalAlignment="Center" Foreground="{StaticResource Text}" />
                    <TextBlock x:Name="DhikrSource" Style="{StaticResource Tiny}" HorizontalAlignment="Center" Margin="0,4,0,0" />
                    <TextBlock x:Name="Count" Text="0" FontSize="64" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource Gold}" Margin="0,10,0,0" />
                    <TextBlock x:Name="Target" Style="{StaticResource Muted}" HorizontalAlignment="Center" />
                    <Button x:Name="TapBtn" Style="{StaticResource PrimaryButton}" Content="Tap to count" Click="Tap_Click" Width="220" Height="60" Margin="0,16,0,0" FontSize="16" />
                    <Button Style="{StaticResource GhostButton}" Content="Reset" Click="Reset_Click" Margin="0,10,0,0" Width="120" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock x:Name="StreakCur" Text="0" FontSize="26" FontWeight="Bold" Foreground="{StaticResource Gold}" HorizontalAlignment="Center" />
                        <TextBlock Text="Current streak" Style="{StaticResource Muted}" HorizontalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock x:Name="StreakMax" Text="0" FontSize="26" FontWeight="Bold" Foreground="{StaticResource Gold}" HorizontalAlignment="Center" />
                        <TextBlock Text="Longest streak" Style="{StaticResource Muted}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
