<UserControl x:Class="SalaamStreet.Desktop.Views.HadithView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28">
        <StackPanel MaxWidth="820" HorizontalAlignment="Left">
            <TextBlock Text="Hadith Library" Style="{StaticResource H1}" />
            <TextBlock Text="Authentic collections with Arabic, English, grading, and reference on every hadith." Style="{StaticResource Muted}" Margin="0,2,0,16" />
            <WrapPanel x:Name="Cats" />
            <StackPanel Orientation="Horizontal" x:Name="BrowseRow" Margin="0,12,0,0" Visibility="Collapsed">
                <TextBox x:Name="NumBox" Width="120" Height="40" />
                <Button Style="{StaticResource PrimaryButton}" Content="Go" Click="Go_Click" Margin="8,0,0,0" />
            </StackPanel>
            <StackPanel x:Name="List" Margin="0,16,0,0" />
            <TextBlock Text="Text served from the open hadith-api. Always verify important rulings with qualified scholars." Style="{StaticResource Tiny}" Margin="0,10,0,0" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
