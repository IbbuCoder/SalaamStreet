<UserControl x:Class="SalaamStreet.Desktop.Views.QiblaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28">
        <StackPanel MaxWidth="640" HorizontalAlignment="Left">
            <TextBlock Text="Qibla Direction" Style="{StaticResource H1}" />
            <TextBlock x:Name="LocLabel" Text="Direction to the Kaaba from your location." Style="{StaticResource Muted}" Margin="0,2,0,16" />

            <Border Style="{StaticResource Card}">
                <StackPanel HorizontalAlignment="Center">
                    <Grid Width="280" Height="280" Margin="10">
                        <Ellipse Stroke="{StaticResource Border}" StrokeThickness="2" Fill="{StaticResource Surface2}" />
                        <TextBlock Text="N" Foreground="{StaticResource Emerald}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,8,0,0" />
                        <TextBlock Text="S" Foreground="{StaticResource Text2}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,8" />
                        <TextBlock Text="E" Foreground="{StaticResource Text2}" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBlock Text="W" Foreground="{StaticResource Text2}" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0" />
                        <Grid x:Name="Needle" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform><RotateTransform x:Name="NeedleRot" Angle="0" /></Grid.RenderTransform>
                            <TextBlock Text="🕋" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,26,0,0" />
                        </Grid>
                    </Grid>
                    <TextBlock x:Name="Degrees" Text="—°" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource Text}" />
                    <TextBlock Text="from true North" Style="{StaticResource Muted}" HorizontalAlignment="Center" />
                    <TextBlock Text="On a desktop there's no compass — face this bearing using a physical compass or your phone. The angle is computed on-device."
                               Style="{StaticResource Muted}" FontSize="11" TextAlignment="Center" Margin="0,10,0,0" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
