<UserControl x:Class="SalaamStreet.Desktop.Views.PrayerTimesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28">
        <StackPanel MaxWidth="760" HorizontalAlignment="Left">
            <TextBlock Text="Prayer Times" Style="{StaticResource H1}" />
            <TextBlock Text="Calculated for your location using your chosen method." Style="{StaticResource Muted}" Margin="0,2,0,16" />

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <DockPanel>
                        <TextBlock x:Name="Hijri" Style="{StaticResource Muted}" DockPanel.Dock="Right" />
                        <TextBlock x:Name="LocLabel" Text="📍 —" Foreground="{StaticResource Text}" FontWeight="SemiBold" />
                    </DockPanel>
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="City" Style="{StaticResource Muted}" />
                            <DockPanel Margin="0,4,0,0">
                                <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Content="Set" Click="SetCity_Click" Margin="6,0,0,0" />
                                <TextBox x:Name="CityBox" Padding="8" Background="{StaticResource Surface2}" Foreground="{StaticResource Text}" BorderBrush="{StaticResource Border}" />
                            </DockPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Calculation method" Style="{StaticResource Muted}" />
                            <ComboBox x:Name="MethodBox" Margin="0,4,0,8" />
                            <TextBlock Text="Asr method" Style="{StaticResource Muted}" />
                            <ComboBox x:Name="SchoolBox" Margin="0,4,0,0" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="Scholars differ on calculation parameters — choose the method your local mosque uses."
                               Style="{StaticResource Muted}" FontSize="11" Margin="0,10,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                <ItemsControl x:Name="TimesList" />
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
