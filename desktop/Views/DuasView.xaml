<UserControl x:Class="SalaamStreet.Desktop.Views.DuasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28">
        <StackPanel MaxWidth="820" HorizontalAlignment="Left">
            <TextBlock Text="Dua Library" Style="{StaticResource H1}" />
            <TextBlock Text="Authentic supplications with sources — every dua cites the Qur'an or a graded hadith." Style="{StaticResource Muted}" Margin="0,2,0,16" />
            <WrapPanel x:Name="Cats" />
            <StackPanel x:Name="List" Margin="0,16,0,0" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
