<UserControl x:Class="SalaamStreet.Desktop.Views.CalendarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28">
        <StackPanel MaxWidth="720" HorizontalAlignment="Left">
            <TextBlock Text="Islamic Calendar" Style="{StaticResource H1}" />
            <TextBlock Text="Today's Hijri date and key Islamic dates." Style="{StaticResource Muted}" Margin="0,2,0,16" />

            <Border Style="{StaticResource HeroCard}">
                <StackPanel>
                    <TextBlock Text="Today" Foreground="#A7F3D0" FontSize="13" />
                    <TextBlock x:Name="HijriText" Text="…" Foreground="White" FontSize="26" FontWeight="Bold" />
                    <TextBlock x:Name="GregText" Text="" Foreground="#A7F3D0" FontSize="13" Margin="0,2,0,0" />
                </StackPanel>
            </Border>

            <TextBlock Text="Key Islamic dates" Style="{StaticResource H2}" Margin="0,20,0,10" />
            <StackPanel x:Name="Events" />
            <TextBlock Text="Gregorian dates depend on moon-sighting and calculation method, and some observances differ among scholars." Style="{StaticResource Tiny}" Margin="0,12,0,0" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
